generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int        @id @default(autoincrement())

  telegramUser  TelegramUser?

  cartItems     CartItem[]
  favoriteItems FavoriteItem[]
  orders        Order[]
  pickupSlotReservations PickupSlotReservation[]

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model TelegramUser {
  id         Int        @id @default(autoincrement())
  userId     Int        @unique
  telegramId BigInt     @unique
  username   String?
  firstName  String?

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Category {
  id       Int       @id @default(autoincrement())
  title    String    @unique
  products Product[]
}

model Product {
  id          Int              @id @default(autoincrement())
  description String
  isActive    Boolean          @default(true)

  categoryId  Int
  category    Category         @relation(fields: [categoryId], references: [id])

  variants    ProductVariant[]
  favoriteItems  FavoriteItem[]

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model ProductVariant {
  id             Int                   @id @default(autoincrement())
  productId      Int
  moySkladId     BigInt

  optionLabel    String
  title          String
  description    String?
  price          Int
  maxQuantity    Int                   @default(1)
  isActive       Boolean               @default(true)
  sortOrder      Int                   @default(0)

  product        Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  images         ProductVariantImage[]
  cartItems      CartItem[]
  orderItems     OrderItem[]

  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@unique([productId, sortOrder])
}

model ProductVariantImage {
  id               Int            @id @default(autoincrement())
  productVariantId Int

  url              String
  sortOrder        Int            @default(0)

  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  @@unique([productVariantId, sortOrder])
}

model FavoriteItem {
  id                   Int            @id @default(autoincrement())
  userId               Int
  productId            Int

  user                 User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  product              Product        @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt            DateTime       @default(now())

  @@unique([userId, productId])
}

model CartItem {
  id                   Int            @id @default(autoincrement())
  userId               Int
  productVariantId     Int
  quantity             Int            @default(1)

  user                 User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  productVariant       ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@unique([userId, productVariantId])
}

model Order {
  id            Int         @id @default(autoincrement())
  userId        Int
  status        OrderStatus @default(CREATED)
  totalPrice    Int

  customerName  String      @default("")
  customerPhone String      @default("")

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items         OrderItem[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([userId])
}

enum OrderStatus {
  CREATED          @map("created")
  PREPARING        @map("preparing")
  DELIVERING       @map("delivering")
  READY_FOR_PICKUP @map("ready_for_pickup")
  COMPLETED        @map("completed")
  CANCELED         @map("canceled")
}

model OrderItem {
  id                   Int             @id @default(autoincrement())
  orderId              Int
  productVariantId     Int?

  variantTitleSnapshot String
  priceSnapshot        Int
  quantity             Int

  order                Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productVariant       ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull)

  createdAt            DateTime        @default(now())

  @@index([orderId])
  @@index([productVariantId])
}

model DeliveryMethod {
  id             Int                           @id @default(autoincrement())
  code           String                        @unique
  title          String
  isActive       Boolean                       @default(false)
  sortOrder      Int                           @default(0)
  paymentMethods DeliveryMethodPaymentMethod[]

  createdAt      DateTime                      @default(now())
  updatedAt      DateTime                      @updatedAt
}

model PaymentMethod {
  id              Int                           @id @default(autoincrement())
  code            String                        @unique
  title           String
  isActive        Boolean                       @default(false)
  sortOrder       Int                           @default(0)
  deliveryMethods DeliveryMethodPaymentMethod[]

  createdAt       DateTime                      @default(now())
  updatedAt       DateTime                      @updatedAt
}

model DeliveryMethodPaymentMethod {
  id               Int            @id @default(autoincrement())
  deliveryMethodId Int
  paymentMethodId  Int

  deliveryMethod   DeliveryMethod @relation(fields: [deliveryMethodId], references: [id], onDelete: Cascade)
  paymentMethod    PaymentMethod  @relation(fields: [paymentMethodId], references: [id], onDelete: Cascade)

  createdAt        DateTime       @default(now())

  @@unique([deliveryMethodId, paymentMethodId])
  @@index([paymentMethodId])
}

model PickupAddress {
  id               Int                     @id @default(autoincrement())
  title            String
  address          String
  description      String?
  isActive         Boolean                 @default(true)
  sortOrder        Int                     @default(0)
  startTimeMinutes Int                     @default(600)
  endTimeMinutes   Int                     @default(1200)
  slotStepMinutes  Int                     @default(30)

  reservations     PickupSlotReservation[]

  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
}

model PickupSlotReservation {
  id                 Int           @id @default(autoincrement())
  pickupAddressId    Int
  pickupDate         DateTime      @db.Date
  pickupTimeMinutes  Int
  userId             Int
  status             String        @default("PENDING")
  moySkladOrderId    String?
  moySkladOrderName  String?
  expiresAt          DateTime?

  pickupAddress      PickupAddress @relation(fields: [pickupAddressId], references: [id], onDelete: Cascade)
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@unique([pickupAddressId, pickupDate, pickupTimeMinutes])
  @@index([userId])
  @@index([status, expiresAt])
}
