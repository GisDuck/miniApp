generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    Int            @id @default(autoincrement())
  moySkladCounterpartyId String?        @unique

  telegramUser          TelegramUser?
  cartItems             CartItem[]
  favoriteItems         FavoriteItem[]
  pickupSlotReservations PickupSlotReservation[]

  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
}

model TelegramUser {
  id         Int      @id @default(autoincrement())
  userId     Int      @unique
  telegramId BigInt   @unique
  username   String?
  firstName  String?

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model FavoriteItem {
  id        Int      @id @default(autoincrement())
  userId    Int
  productId String

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([productId])
}

model CartItem {
  id               Int      @id @default(autoincrement())
  userId           Int
  productVariantId String
  quantity         Int      @default(1)

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, productVariantId])
  @@index([productVariantId])
}

model DeliveryMethod {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  title     String
  isActive  Boolean  @default(false)
  sortOrder Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PickupAddress {
  id               Int                     @id @default(autoincrement())
  title            String
  address          String
  isActive         Boolean                 @default(true)
  sortOrder        Int                     @default(0)
  startTimeMinutes Int                     @default(600)
  endTimeMinutes   Int                     @default(1200)
  slotStepMinutes  Int                     @default(30)

  reservations     PickupSlotReservation[]

  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
}

model PickupSlotReservation {
  id                 Int           @id @default(autoincrement())
  pickupAddressId    Int
  pickupDate         DateTime      @db.Date
  pickupTimeMinutes  Int
  userId             Int
  status             String        @default("PENDING")
  moySkladOrderId    String?
  moySkladOrderName  String?
  expiresAt          DateTime?

  pickupAddress      PickupAddress @relation(fields: [pickupAddressId], references: [id], onDelete: Cascade)
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@unique([pickupAddressId, pickupDate, pickupTimeMinutes])
  @@index([userId])
  @@index([status, expiresAt])
}
